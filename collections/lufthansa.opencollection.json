              {
                "name": "destination",
                "value": "",
                "type": "path",
                "description": "Destination airport. 3-letter IATA airport code (e.g. 'MUC')"
              },
              {
                "name": "date",
                "value": "",
                "type": "path",
                "description": "Departure date (YYYY-MM-DD)"
